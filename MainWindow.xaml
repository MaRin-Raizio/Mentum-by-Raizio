<Window
    x:Class="MentumLauncher.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Mentum Launcher 2.0.0"
    Width="950"
    Height="650"
    Background="#2E2E2E"
    FontFamily="pack://application:,,,/Fonts/#Exo 2">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!--  Encabezado  -->
            <RowDefinition Height="2*" />
            <!--  Botones principales  -->
            <RowDefinition Height="Auto" />
            <!--  Botón gris  -->
            <RowDefinition Height="Auto" />
            <!--  Opciones avanzadas  -->
            <RowDefinition Height="3*" />
            <!--  Bloque log + progreso + firma  -->
        </Grid.RowDefinitions>

        <!--  Encabezado  -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                Style="{StaticResource TitleText}"
                Text="Mentum Launcher 2.0.0" />

            <Button
                Grid.Column="1"
                Margin="10,0,0,0"
                Padding="5"
                Background="White"
                Click="Logo_Click">
                <Image
                    Width="40"
                    Height="40"
                    Source="pack://application:,,,/Resources/logo.png" />
            </Button>
        </Grid>

        <!--  Botones principales  -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Columna izquierda  -->
            <Button
                Grid.Row="0"
                Grid.Column="0"
                Margin="5"
                Background="#228B22"
                Click="BtnQuickRepair_Click"
                Content="Reparación rápida del sistema" />
            <Button
                Grid.Row="1"
                Grid.Column="0"
                Margin="5"
                Background="#006400"
                Click="BtnRestoreImage_Click"
                Content="Restaurar archivos esenciales de Windows" />
            <Button
                Grid.Row="2"
                Grid.Column="0"
                Margin="5"
                Background="#228B22"
                Click="BtnTempCleanup_Click"
                Content="Limpiar archivos temporales" />
            <Button
                Grid.Row="3"
                Grid.Column="0"
                Margin="5"
                Background="#006400"
                Click="BtnResetNetwork_Click"
                Content="Reparar configuración de red" />

            <!--  Columna derecha  -->
            <Button
                Grid.Row="0"
                Grid.Column="1"
                Margin="5"
                Background="#006400"
                Click="BtnDeepScan_Click"
                Content="Escaneo profundo de la imagen de Windows" />
            <Button
                Grid.Row="1"
                Grid.Column="1"
                Margin="5"
                Background="#228B22"
                Click="BtnDiskCheck_Click"
                Content="Revisión y reparación de disco" />
            <Button
                Grid.Row="2"
                Grid.Column="1"
                Margin="5"
                Background="#006400"
                Click="BtnDiskOptimization_Click"
                Content="Optimizar rendimiento del disco" />
            <Button
                Grid.Row="3"
                Grid.Column="1"
                Margin="5"
                Background="#1E90FF"
                Click="BtnFullMaintenance_Click"
                Content="Mantenimiento completo del sistema" />
        </Grid>

        <!--  Botón gris  -->
        <Button
            Grid.Row="2"
            Margin="0,10"
            Background="#708090"
            Click="BtnSystemInfo_Click"
            Content="Ver información del sistema" />

        <!--  Opciones avanzadas  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,10"
            Orientation="Vertical">
            <Button
                Margin="0,5"
                Background="#6A0DAD"
                Click="BtnAvanzado_Click"
                Content="Herramientas avanzadas" />
            <Button
                Margin="0,5"
                Background="#FF6347"
                Click="BtnCerrar_Click"
                Content="Salir de Mentum" />
        </StackPanel>

        <!--  Bloque log + progreso + firma  -->
        <Grid Grid.Row="4" Margin="0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!--  LogBox ocupa la mayor parte  -->
                <RowDefinition Height="Auto" />
                <!--  Progreso  -->
                <RowDefinition Height="Auto" />
                <!--  Firma  -->
            </Grid.RowDefinitions>

            <!--  Log  -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Registro de acciones:" />
                <RichTextBox
                    x:Name="LogBox"
                    Grid.Row="1"
                    Margin="0,0,0,10"
                    Background="#D3D3D3"
                    FontFamily="pack://application:,,,/Fonts/#Orbitron"
                    FontSize="12"
                    FontWeight="Normal"
                    Foreground="Black"
                    IsReadOnly="True"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>

            <!--  Progreso  -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock
                    FontWeight="Bold"
                    Foreground="White"
                    Text="Progreso:" />
                <ProgressBar
                    x:Name="ProgressBar"
                    Height="20"
                    Maximum="100"
                    Minimum="0" />
            </StackPanel>

            <!--  Firma morada  -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,0"
                HorizontalAlignment="Center">
                <TextBlock
                    Margin="0,2"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#9000F9">
                    🖥️ MaRin Raizio
                </TextBlock>
                <TextBlock
                    Margin="0,2"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#9000F9">
                    🎵 TikTok:<Hyperlink NavigateUri="https://www.tiktok.com/@MaRin_Raizio" RequestNavigate="Hyperlink_RequestNavigate">@MaRin_Raizio</Hyperlink>
                </TextBlock>
                <TextBlock
                    Margin="0,2"
                    FontSize="12"
                    FontWeight="Bold"
                    Foreground="#9000F9">
                    💜☕ Invítame un Café:<Hyperlink NavigateUri="https://ko-fi.com/marin_raizio" RequestNavigate="Hyperlink_RequestNavigate">ko-fi.com/marin_raizio</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Grid>
</Window>