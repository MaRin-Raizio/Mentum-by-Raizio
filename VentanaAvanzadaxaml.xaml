<Window
    x:Class="MentumLauncher.VentanaAvanzada"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Opciones avanzadas"
    Width="700"
    Height="500"
    Background="#2E2E2E"
    FontFamily="pack://application:,,,/Fonts/#Exo 2">

    <StackPanel Margin="15">
        <!--  Título  -->
        <TextBlock
            Margin="0,0,0,20"
            FontSize="22"
            FontWeight="Bold"
            Foreground="#9000F9"
            Text="Opciones avanzadas de Mentum" />

        <!--  Lista de comandos reales  -->
        <ListBox
            Name="ListaComandos"
            Height="300"
            Margin="0,0,0,15"
            Background="#D3D3D3"
            FontFamily="pack://application:,,,/Fonts/#Consolas"
            Foreground="Black">

            <!--  Comandos tal cual  -->
            <ListBoxItem Content="sfc /scannow" />
            <ListBoxItem Content="DISM /Online /Cleanup-Image /RestoreHealth" />
            <ListBoxItem Content="DISM /Online /Cleanup-Image /ScanHealth" />
            <ListBoxItem Content="DISM /Online /Cleanup-Image /CheckHealth" />
            <ListBoxItem Content="chkdsk C: /f /r" />
            <ListBoxItem Content="ipconfig /flushdns" />
            <ListBoxItem Content="netsh winsock reset" />
            <ListBoxItem Content="netsh int ip reset" />
            <ListBoxItem Content="systeminfo" />
            <ListBoxItem Content="defrag C: /O" />
            <ListBoxItem Content="tasklist" />
            <ListBoxItem Content="powercfg /energy" />
            <ListBoxItem Content="fsutil behavior query DisableDeleteNotify" />
        </ListBox>

        <!--  Botón de ejecución  -->
        <Button
            Margin="0,0,0,10"
            Background="#32CD32"
            Click="BtnEjecutar_Click"
            Content="Ejecutar comando seleccionado"
            FontWeight="Bold"
            Foreground="Black" />

        <!--  Botón de cierre/regreso  -->
        <Button
            Background="#FF6347"
            Click="BtnCerrar_Click"
            Content="Regresar al menú básico"
            FontWeight="Bold"
            Foreground="White" />
    </StackPanel>
</Window>