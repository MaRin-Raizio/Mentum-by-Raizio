<Window x:Class="MentumLauncher.VentanaInfoSistema"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Información del Sistema" Height="700" Width="900"
        Background="#2E2E2E" Foreground="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CPU -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Uso de CPU:" FontWeight="Bold"/>
            <ProgressBar Name="CpuBar" Height="20" Minimum="0" Maximum="100" Background="#D3D3D3"/>
            <TextBlock Name="CpuLabel" Text="0%" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- RAM -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Uso de RAM:" FontWeight="Bold"/>
            <ProgressBar Name="RamBar" Height="20" Minimum="0" Maximum="100" Background="#D3D3D3"/>
            <TextBlock Name="RamLabel" Text="0 MB usados / 0 MB totales" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Discos -->
        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Espacio en discos:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox Name="DiskList" Background="#D3D3D3" Foreground="Black"/>
        </StackPanel>

        <!-- Detalles del sistema -->
        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Detalles del sistema:" FontWeight="Bold" Margin="0,0,0,10"/>
            <ListBox Name="SystemDetailsList" Background="#D3D3D3" Foreground="Black"/>
        </StackPanel>

        <!-- Botón regresar -->
        <StackPanel Grid.Row="4" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Regresar al menú principal" Width="220" Height="40"
                    Background="#4CAF50" Foreground="White"
                    Click="BtnRegresar_Click"/>
        </StackPanel>
    </Grid>
</Window>